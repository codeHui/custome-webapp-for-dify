# NEXT_PUBLIC_AGENT_CONFIGS=[{"name":"Agent 1","appId":"your-first-app-id","apiKey":"app-your-first-key"},{"name":"Agent 2","appId":"your-second-app-id","apiKey":"app-your-second-key"}]
